#!/data/data/com.inshal.hello/files/bin/ash
# yoangelo - custom system info fetch for Tilde

GREEN="\033[1;32m"
CYAN="\033[1;36m"
YELLOW="\033[1;33m"
RESET="\033[0m"
BOLD="\033[1m"

MODEL=$(getprop ro.product.model)
MANUFACTURER=$(getprop ro.product.manufacturer)
CODENAME=$(getprop ro.product.device)
ANDROID_VER=$(getprop ro.build.version.release)
KERNEL=$(uname -r)
UPTIME_RAW=$(cut -d' ' -f1 /proc/uptime 2>/dev/null)
UPTIME_MIN=$(( ${UPTIME_RAW%.*} / 60 ))
CPU_MODEL=$(grep -m1 "Hardware" /proc/cpuinfo | cut -d':' -f2 | sed 's/^ //')
CPU_CORES=$(grep -c "^processor" /proc/cpuinfo)
MEM_TOTAL_KB=$(grep "MemTotal" /proc/meminfo | awk '{print $2}')
MEM_FREE_KB=$(grep "MemAvailable" /proc/meminfo | awk '{print $2}')
MEM_TOTAL_MB=$(( MEM_TOTAL_KB / 1024 ))
MEM_USED_MB=$(( (MEM_TOTAL_KB - MEM_FREE_KB) / 1024 ))
SHELL_NAME="ash (busybox)"
TERM_APP="Tilde"

printf "\n"
printf "%b    >~|   %b%b%s %s%b\n" "$GREEN" "$RESET" "$BOLD" "$MANUFACTURER" "$MODEL" "$RESET"
printf "%b   /___\\  %b------------------------\n" "$GREEN" "$RESET"
printf "%b  |     | %b%bOS%b       Android %s\n" "$GREEN" "$RESET" "$CYAN" "$RESET" "$ANDROID_VER"
printf "%b  |     | %b%bDevice%b   %s\n" "$GREEN" "$RESET" "$CYAN" "$RESET" "$CODENAME"
printf "%b   \\___/  %b%bKernel%b   %s\n" "$GREEN" "$RESET" "$CYAN" "$RESET" "$KERNEL"
printf "%b          %b%bUptime%b   %sm\n" "$GREEN" "$RESET" "$CYAN" "$RESET" "$UPTIME_MIN"
printf "%b          %b%bShell%b    %s\n" "$GREEN" "$RESET" "$CYAN" "$RESET" "$SHELL_NAME"
printf "%b          %b%bTerm%b     %s\n" "$GREEN" "$RESET" "$CYAN" "$RESET" "$TERM_APP"
printf "%b          %b%bCPU%b      %s (%s cores)\n" "$GREEN" "$RESET" "$CYAN" "$RESET" "$CPU_MODEL" "$CPU_CORES"
printf "%b          %b%bMemory%b   %sMB / %sMB\n" "$GREEN" "$RESET" "$CYAN" "$RESET" "$MEM_USED_MB" "$MEM_TOTAL_MB"
printf "\n"
printf "%b  yo angelo!%b\n" "$YELLOW" "$RESET"
printf "\n"
